<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Chicken Road Premium</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        :root {
            --bg-color: #1a1a1a;
            --panel-color: #2a2a2a;
            --green-color: #58a65c;
            --gold-color: #bfa15f;
            --text-color: #ffffff;
        }

        body {
            margin: 0;
            padding: 0;
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: 'Arial', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            height: 100vh;
            overflow: hidden;
        }

        /* Top Bar */
        .header {
            width: 90%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 5%;
            background-color: #111;
        }

        .logo {
            font-weight: bold;
            font-size: 18px;
            color: #fff;
        }
        .logo span { color: #f39c12; }

        .balance-box {
            background-color: #222;
            padding: 5px 15px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            border: 1px solid #444;
        }

        .balance-box span {
            color: #f1c40f;
            margin-left: 5px;
            font-weight: bold;
        }

        /* Spielfeld */
        #game-container {
            flex: 1;
            width: 100%;
            max-width: 400px;
            position: relative;
            background-color: #333;
            background-image: linear-gradient(#444 2px, transparent 2px), linear-gradient(90deg, #444 2px, transparent 2px);
            background-size: 40px 40px;
        }

        /* Steuerungs-Panel unten */
        .control-panel {
            width: 90%;
            max-width: 400px;
            background-color: var(--panel-color);
            border-top-left-radius: 20px;
            border-top-right-radius: 20px;
            padding: 20px 5%;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .bet-selection {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 5px;
        }

        .bet-btn {
            background-color: #333;
            border: 1px solid #444;
            color: white;
            padding: 10px;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
        }

        .action-btns {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .btn-main {
            padding: 18px;
            border: none;
            border-radius: 12px;
            font-size: 18px;
            font-weight: bold;
            color: white;
            cursor: pointer;
        }

        .btn-cashout { background-color: var(--gold-color); }
        .btn-go { background-color: var(--green-color); }

        /* Menüs (Shop, Einstellungen, Wallet) */
        .nav-menu {
            display: flex;
            gap: 10px;
        }
        .nav-item {
            background: none;
            border: none;
            color: white;
            font-size: 20px;
            cursor: pointer;
        }

        .overlay-menu {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background-color: rgba(0,0,0,0.9);
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 10;
        }
    </style>
</head>
<body>

    <div class="header">
        <div class="logo">CHICKEN<span>2</span>ROAD</div>
        <div style="display: flex; align-items: center; gap: 10px;">
            <div class="balance-box" onclick="openMenu('shop')">
                <div id="user-balance">100</div> <span>🪙</span>
            </div>
            <div class="nav-menu">
                <button class="nav-item" onclick="openMenu
('settings')">⚙️</button>
                <button class="nav-item" onclick="openMenu('wallet')">👛</button>
            </div>
        </div>
    </div>

    <div id="game-container">
        </div>

    <div class="control-panel">
        <div class="bet-selection">
            <button class="bet-btn" onclick="setBet(0.5)">0.5 🪙</button>
            <button class="bet-btn" onclick="setBet(1)">1 🪙</button>
            <button class="bet-btn" onclick="setBet(2)">2 🪙</button>
            <button class="bet-btn" onclick="setBet(5)">5 🪙</button>
        </div>

        <div class="action-btns">
            <button class="btn-main btn-cashout" onclick="cashOut()">CASH OUT<br><span id="win-amount">0.00 USD</span></button>
            <button class="btn-main btn-go" onclick="startGame()">GO</button>
        </div>
    </div>

    <div id="shop-menu" class="overlay-menu">
        <h2>MÜNZ-SHOP</h2>
        <button onclick="buyCoins(10, 10)">10 Münzen = 10€</button><br>
        <button onclick="buyCoins(50, 50)">50 Münzen = 50€</button><br>
        <button onclick="buyCoins(100, 80)">100 Münzen = 80€</button><br>
        <button onclick="closeMenus()">Schließen</button>
    </div>

    <div id="settings-menu" class="overlay-menu">
        <h2>SPRACHE / LANGUAGE</h2>
        <button onclick="setLanguage('de')">Deutsch</button>
        <button onclick="setLanguage('tr')">Türkçe</button>
        <button onclick="setLanguage('ar')">العربية</button>
        <button onclick="setLanguage('en')">English</button>
        <button onclick="setLanguage('ru')">Русский</button><br>
        <button onclick="closeMenus()">Schließen</button>
    </div>

    <div id="wallet-menu" class="overlay-menu">
        <h2>AUSZAHLUNG / WALLET</h2>
        <input type="text" id="paypal-email" placeholder="PayPal E-Mail Adresse" style="padding: 10px; width: 80%;"><br>
        <button onclick="saveWallet()">Speichern & Auszahlen</button><br>
        <button onclick="closeMenus()">Schließen</button>
    </div>

    <script>
        const tg = window.Telegram.WebApp;
        tg.expand();

        let balance = 100;
        let currentBet = 1;
        let currentProfit = 0;
        let currentStep = 0;
        let gameActive = false;

        function openMenu(menuId) {
            closeMenus();
            document.getElementById(menuId + '-menu').style.display = 'flex';
        }

        function closeMenus() {
            document.querySelectorAll('.overlay-menu').forEach(m => m.style.display = 'none');
        }

        function setBet(amount) {
            if(!gameActive) {
                currentBet = amount;
                tg.HapticFeedback.impactOccurred("light");
            }
        }

        function startGame() {
            if(!gameActive) {
                if(balance < currentBet) {
                    alert("Nicht genug Münzen! Bitte im Shop aufladen.");
                    return;
                }
                balance -= currentBet;
                document.getElementById('user-balance').innerText = balance;
                gameActive = true;
                currentStep = 1;
                currentProfit = currentBet * 1.98;
                document.getElementById('win-amount').innerText = currentProfit.toFixed(2) + " USD";
            } else {
                // Ein Schritt nach vorne gehen (Risiko-Check)
                currentStep++;
                let crashChance = Math.random();
                if (crashChance < 0.25) { // 25% Chance zu verlieren
                    alert("BOOM! Verloren!");
                    gameActive = false;
                    currentProfit = 0;
                    document.getElementById('win-amount').innerText = "0.00 USD";
                } else {
                    currentProfit += 0.05; // 5 Cent Gewinn pro Schritt dazu
                    document.getElementById('win-amount').innerText = currentProfit.toFixed(2) + " USD";
                }
            }
            tg.HapticFeedback.impactOccurred("medium");
        }

        function cashOut() {
            if(gameActive && currentProfit > 0) {
                alert("Erfolgreich ausgezahlt: " + currentProfit.toFixed(2) + " USD");
                // Hier würde der Gewinn wieder in Münzen oder Guthaben umgerechnet
                gameActive = false;
                currentProfit = 0;
                document.getElementById('win-amount').innerText = "0.00 USD";
                tg.HapticFeedback.notificationOccurred("success");
            }
        }

        function setLanguage(lang) {
            alert("Sprache geändert auf: " + lang);
            closeMenus();
        }

        function buyCoins(amount, price) {
            alert("Du kaufst " + amount + " Münzen für " + price + "€. Hier binden wir als nächstes Telegram Stars ein.");
        }
    </script>
</body>
</html>
